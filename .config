# =========================
# x86_64 基础目标
# =========================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# =========================
# ROOTFS 大小（推荐2GB）
# =========================
CONFIG_TARGET_ROOTFS_PARTSIZE=2048

# =========================
# 开发与编译优化
# =========================
CONFIG_DEVEL=y
CONFIG_CCACHE=y

# =========================
# 全局 OpenSSL（彻底禁用 mbedtls）
# =========================
CONFIG_PACKAGE_libustream-openssl=y
# CONFIG_PACKAGE_libustream-mbedtls is not set

CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_openssl-util=y

# LuCI HTTPS 强制 OpenSSL
CONFIG_PACKAGE_luci-ssl-openssl=y
# CONFIG_PACKAGE_luci-ssl is not set

# =========================
# IPv6 全关闭（非常关键）
# =========================
CONFIG_IPV6=n

# CONFIG_PACKAGE_kmod-ipv6 is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set
# CONFIG_PACKAGE_ipv6helper is not set
# CONFIG_PACKAGE_dnsmasq_full_dhcpv6 is not set

# =========================
# LuCI 基础
# =========================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-apk=y

# 中文
CONFIG_LUCI_LANG_zh_Hans=y

CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-apk-zh-cn=y

# =========================
# 基础工具
# =========================
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y

# =========================
# Firewall4 + nftables（核心）
# =========================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y

CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_iptables-mod-tproxy=y

CONFIG_PACKAGE_kmod-tun=y

# =========================
# DNS（PassWall/Nikki关键）
# =========================
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set

# =========================
# Nikki（主代理）
# =========================
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y

# Nikki 主核心
CONFIG_PACKAGE_mihomo=y

# =========================
# PassWall（备用代理）
# =========================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# PassWall 核心
CONFIG_PACKAGE_sing-box=y

# 禁止编译巨大垃圾核心（避免爆内存）
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_v2ray-core is not set
# CONFIG_PACKAGE_trojan-plus is not set

# =========================
# Samba4 文件共享
# =========================
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y

CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-utils=y

# =========================
# USB 与硬盘支持
# =========================

# USB基础驱动
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y

CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-xhci-pci=y

CONFIG_PACKAGE_usbutils=y

# USB存储
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

# 自动挂载
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blockd=y

# 文件系统
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y

CONFIG_PACKAGE_ntfs3-mount=y

CONFIG_PACKAGE_exfat-fsck=y
CONFIG_PACKAGE_exfat-mkfs=y

CONFIG_PACKAGE_kmod-nls-utf8=y

# =========================
# 硬盘休眠
# =========================
CONFIG_PACKAGE_hd-idle=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y

# =========================
# p910nd 打印机共享
# =========================
CONFIG_PACKAGE_p910nd=y
CONFIG_PACKAGE_luci-app-p910nd=y
CONFIG_PACKAGE_luci-i18n-p910nd-zh-cn=y

CONFIG_PACKAGE_kmod-usb-printer=y

# =========================
# Argon 主题
# =========================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

CONFIG_PACKAGE_luci-lib-ipkg=y

# =========================
# TTYD
# =========================
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# =========================
# UPnP
# =========================
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y

# =========================
# EFI / GRUB
# =========================
CONFIG_GRUB_IMAGES=y
CONFIG_EFI_IMAGES=y

# =========================
# 明确关闭不需要功能
# =========================

# 文件传输
# CONFIG_PACKAGE_luci-app-filetransfer is not set

# 负载均衡
# CONFIG_PACKAGE_luci-app-mwan3 is not set
# CONFIG_PACKAGE_mwan3 is not set

# irqbalance
# CONFIG_PACKAGE_luci-app-irqbalance is not set

# Docker
# CONFIG_PACKAGE_luci-app-dockerman is not set

# OpenClash（避免冲突）
# CONFIG_PACKAGE_luci-app-openclash is not set

# MosDNS
# CONFIG_PACKAGE_luci-app-mosdns is not set

# AdGuardHome
# CONFIG_PACKAGE_luci-app-adguardhome is not set

# TurboACC
# CONFIG_PACKAGE_luci-app-turboacc is not set

# Flow Offload
# CONFIG_PACKAGE_kmod-shortcut-fe is not set
# CONFIG_PACKAGE_kmod-shortcut-fe-cm is not set

# automount（旧版）
# CONFIG_PACKAGE_automount is not set
